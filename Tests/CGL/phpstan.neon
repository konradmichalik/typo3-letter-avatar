includes:
	- %rootDir%/../../konradmichalik/phpstan-typo3-preset/phpstan.neon.dist
	- phpstan-baseline.neon

parameters:
	level: 8

	scanDirectories:
		- ../../vendor
		- ../../vendor/phpunit/phpunit/src
	paths:
		- ../../Classes
		- ../../Configuration
		- ../../Resources

	excludePaths:
		- ../../.Build (?)

	type_coverage:
		constant: 0
