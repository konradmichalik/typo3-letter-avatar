{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"github>konradmichalik/renovate-config",
		"github>konradmichalik/renovate-config:typo3-extension"
	],
	"ignorePaths": [
		"package-lock.json"
	],
	"composerIgnorePlatformReqs": ["ext-*", "lib-*"],
	"constraints": {
		"php": "~8.2.0"
	},
	"packageRules": [
		{
			"matchPackageNames": ["php"],
			"enabled": false
		}
	]
}
